# Supabase Configuration
# Get these from your Supabase Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# GitHub OAuth Configuration
# Get these from your GitHub Settings > Developer settings > OAuth Apps
AUTH_GITHUB_ID=your_github_client_id
AUTH_GITHUB_SECRET=your_github_client_secret

# Auth.js Secret
# Run `openssl rand -base64 32` to generate a secret key
AUTH_SECRET=your_random_secret_key

# MiniMax AI Configuration
# Get these from your MiniMax Dashboard
MINIMAX_GROUP_ID=your_minimax_group_id
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_MODEL=abab6.5-chat

# App Configuration
# For local dev: http://localhost:3000
# For production: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
